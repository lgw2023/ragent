# Copy this file to .env on the target server, then fill in the model endpoint
# URLs and keys that are reachable from that server.

# Remote OpenAI-compatible model services. Keep these pointed at the only
# network endpoints allowed in the target environment.
LLM_MODEL=qwen3-32b
LLM_MODEL_URL=http://127.0.0.1:8000/compatible-mode/v1
LLM_MODEL_KEY=replace-me

EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_MODEL_URL=http://127.0.0.1:8000/compatible-mode/v1
EMBEDDING_MODEL_KEY=replace-me
EMBEDDING_DIMENSIONS=1024

RERANK_MODEL=qwen3-rerank
RERANK_MODEL_URL=http://127.0.0.1:8000/compatible-api/v1/reranks
RERANK_MODEL_KEY=replace-me

IMAGE_MODEL=qwen3-vl-flash
IMAGE_MODEL_URL=http://127.0.0.1:8000/compatible-mode/v1
IMAGE_MODEL_KEY=replace-me

# MinerU offline local models. tools/bootstrap_offline_runtime.sh rewrites
# .runtime/mineru.json with absolute paths for the current server.
MINERU_PARSE_MODE=pipeline
MINERU_PIPELINE_METHOD=txt
MINERU_HYBRID_METHOD=auto
MINERU_VLM_BACKEND=auto
MINERU_MODEL_SOURCE=local
MINERU_TOOLS_CONFIG_JSON=.runtime/mineru.json

# Force common model loaders to stay offline.
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
TOKENIZERS_PARALLELISM=false

MAX_ASYNC=4
LLM_API_TIMEOUT_SECONDS=120
RAG_INDEX_TIMEOUT_SECONDS=3600
RAG_INSERT_TIMEOUT_SECONDS=3600
RAG_INSERT_TIMEOUT_MAX_SECONDS=14400
